# Contoh reverse proxy untuk self-host OpenCLAWN di VPS publik (§P0 production-readiness).
#
# Caddy otomatis mengurus sertifikat TLS (Let's Encrypt) — cukup domain yang
# sudah menunjuk ke IP server ini. Ini SATU-SATUNYA cara direkomendasikan untuk
# expose OpenCLAWN ke internet: jangan bind uvicorn langsung ke 0.0.0.0 tanpa
# TLS di depannya (kredensial login & konten chat akan lewat plaintext).
#
# Pemakaian:
#   1. cp Caddyfile.example Caddyfile
#   2. Ganti openclawn.example.com dengan domain Anda
#   3. Isi OPENCLAWN_AUTH_TOKEN di .env (WAJIB untuk akses publik, lihat .env.example)
#   4. caddy run   (atau tambahkan sebagai service di docker-compose.yml)

openclawn.example.com {
    reverse_proxy localhost:8000

    # SSE (/chat/stream, /converse/stream) butuh buffering dimatikan agar token
    # streaming sampai ke browser real-time, bukan menumpuk di buffer proxy.
    flush_interval -1

    # Header keamanan dasar — pelengkap CSRF/auth di level aplikasi, bukan pengganti.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "same-origin"
    }

    encode gzip
    log {
        output file /var/log/caddy/openclawn.log
    }
}

# OpenConnector (opsional, third-party — https://github.com/oomol-lab/open-connector,
# Apache-2.0 oleh oomol-lab) — dashboard + API gateway 1000+ provider SaaS,
# dijalankan sebagai container Docker terpisah (docker-compose.yml § connector,
# profile "connector"). Update = docker compose pull connector, image resmi
# tidak dimodifikasi/di-vendor ke repo ini.
#
# SUBDOMAIN, bukan subpath — Web Console mereka (React/Vite) referensi asset
# dengan path absolut dari root ("/assets/..."), jadi tak aman di-mount di
# subpath (mis. openclawn.example.com/connector) tanpa modifikasi build mereka.
# Ganti "connector.example.com" dengan subdomain Anda sendiri, DNS A/CNAME
# harus menunjuk ke server yang sama sebelum Caddy bisa terbitkan TLS untuknya.
connector.example.com {
    reverse_proxy localhost:3000

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "same-origin"
    }

    encode gzip
    log {
        output file /var/log/caddy/connector.log
    }
}
