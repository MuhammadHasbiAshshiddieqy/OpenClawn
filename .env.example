# Salin file ini ke .env dan isi nilainya
# cp .env.example .env

# === LLM ===
ANTHROPIC_API_KEY=sk-ant-...

# Google AI Studio (Gemini). Key gratis di https://aistudio.google.com/apikey
GOOGLE_API_KEY=...

# === Database ===
# Default: data/openclawn.db (relatif dari root project)
# OPENCLAWN_DB=data/openclawn.db

# === Ollama ===
# Default: http://localhost:11434
# OLLAMA_BASE=http://localhost:11434

# === Anthropic API base (opsional, untuk proxy) ===
# ANTHROPIC_BASE=https://api.anthropic.com

# === Self-host auth (opsional, WAJIB bila diakses dari internet) ===
# Kosong (default) = auth DIMATIKAN — aman HANYA di localhost/VPN/Tailscale.
# Isi dengan password acak yang panjang bila self-host di VPS publik.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# OPENCLAWN_AUTH_TOKEN=

# === Idle timeout (opsional, hanya berpengaruh bila OPENCLAWN_AUTH_TOKEN diisi) ===
# Kosong (default) = OFF — sesi hanya dibatasi absolute expiry 7 hari sejak login.
# Isi (detik) untuk logout otomatis setelah periode TAK aktif — nilai jual untuk
# kebijakan keamanan sesi ketat (bank/finance/compliance).
# OPENCLAWN_IDLE_TIMEOUT_SEC=1800

# === OpenConnector (opsional, third-party — github.com/oomol-lab/open-connector, Apache-2.0) ===
# Hanya relevan bila `docker compose --profile connector up` dijalankan (lihat
# docker-compose.yml § connector, docs/tools.md § Integrasi OpenConnector).
# Public origin OpenConnector — WAJIB diisi bila diakses lewat domain publik
# (reverse-proxy, Caddyfile.example § connector.example.com), agar redirect
# OAuth provider mengarah ke domain yang benar, bukan localhost:3000 internal.
# OOMOL_CONNECT_ORIGIN=https://connector.example.com
# Token bearer untuk proteksi dashboard/API admin OpenConnector. Kosong = tanpa
# token (aman HANYA di localhost/jaringan tepercaya, sama semangat OPENCLAWN_AUTH_TOKEN).
# OOMOL_CONNECT_ADMIN_TOKEN=
# Enkripsi kredensial provider yang tersimpan di OpenConnector (API key, OAuth token).
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# OOMOL_CONNECT_ENCRYPTION_KEY=
# URL dashboard OpenConnector untuk entry point link di sidebar OpenCLAWN. Kosong
# (default) = link TAK ditampilkan (integrasi tetap opt-in). Isi bila container
# `connector` di atas dijalankan — localhost:3000 untuk dev, OOMOL_CONNECT_ORIGIN
# untuk deployment publik.
# OPENCLAWN_CONNECTOR_URL=http://localhost:3000
